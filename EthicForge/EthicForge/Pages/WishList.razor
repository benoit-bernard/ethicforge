@page "/wishlist"

<PageTitle>WishList — EthicForge</PageTitle>

<div class="wishlist-hero">
    <div class="wishlist-hero__glow"></div>
    <div class="container">
        <div class="wishlist-hero__content">
            <div class="wishlist-hero__eyebrow">
                <span class="badge badge--accent">Beta</span>
                <span class="badge badge--primary">Free &amp; Open Source</span>
            </div>
            <h1 class="wishlist-hero__title">WishList</h1>
            <p class="wishlist-hero__subtitle">
                Organize your wishes, share them with the people you love —
                without ads, without tracking, without selling your data.
            </p>
            <div class="wishlist-hero__actions">
                <a class="btn btn-primary" href="#features">Discover the features</a>
                <a class="btn btn-outline" href="https://engawa.fr" target="_blank" rel="noopener noreferrer">
                    forged by engawa ⌥
                </a>
            </div>
        </div>

        <div class="wishlist-hero__preview">
            <div class="app-preview">
                <div class="app-preview__bar">
                    <span class="app-preview__dot app-preview__dot--red"></span>
                    <span class="app-preview__dot app-preview__dot--orange"></span>
                    <span class="app-preview__dot app-preview__dot--green"></span>
                    <span class="app-preview__url">wishlist.ethicforge.com</span>
                </div>
                <div class="app-preview__body">
                    <div class="app-preview__wish app-preview__wish--highlighted">
                        🎸 <span>Fender Telecaster</span>
                        <span class="app-preview__wish-tag">Music</span>
                    </div>
                    <div class="app-preview__wish">
                        📚 <span>Domain-Driven Design (Evans)</span>
                        <span class="app-preview__wish-tag">Books</span>
                    </div>
                    <div class="app-preview__wish">
                        🎮 <span>Elden Ring DLC</span>
                        <span class="app-preview__wish-tag">Gaming</span>
                    </div>
                    <div class="app-preview__wish">
                        🧳 <span>Japan trip — Spring 2026</span>
                        <span class="app-preview__wish-tag">Travel</span>
                    </div>
                    <div class="app-preview__add">+ Add a wish</div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="section" id="features">
    <div class="container">
        <SectionTitle Title="Everything you need, nothing more"
                      Subtitle="WishList is intentionally simple. No bloat, no distractions — just a clean, private tool that does one thing well."
                      Eyebrow="Features" />

        <div class="features-grid stagger-in">
            <div class="feature">
                <span class="feature__icon">📋</span>
                <h3>Create your lists</h3>
                <p>Organise your wishes by occasion, category or priority. Birthday, Christmas, travel — any theme you like.</p>
            </div>
            <div class="feature">
                <span class="feature__icon">🔗</span>
                <h3>Share with a link</h3>
                <p>Generate a private link to share your list with family and friends. No account required on their side.</p>
            </div>
            <div class="feature">
                <span class="feature__icon">🎁</span>
                <h3>Reserve gifts secretly</h3>
                <p>Friends can mark a gift as reserved without you seeing it — avoiding duplicates while keeping the surprise.</p>
            </div>
            <div class="feature">
                <span class="feature__icon">🔒</span>
                <h3>Private by design</h3>
                <p>Your data is never sold, shared or used for advertising. Lists are private by default.</p>
            </div>
            <div class="feature">
                <span class="feature__icon">📱</span>
                <h3>Works on all devices</h3>
                <p>Fully responsive design — manage your lists on phone, tablet or desktop seamlessly.</p>
            </div>
            <div class="feature">
                <span class="feature__icon">🌐</span>
                <h3>EU hosted</h3>
                <p>All data stored exclusively in Europe. Compliant with GDPR and French data protection law.</p>
            </div>
        </div>
    </div>
</section>

<section class="section section--alt">
    <div class="container">
        <SectionTitle Title="Ethical commitments"
                      Subtitle="WishList is not just another app. It embodies every EthicForge principle."
                      Eyebrow="Our Promise" />

        <div class="commitments stagger-in">
            <div class="commitment">
                <span>🚫</span>
                <div>
                    <strong>No advertising</strong>
                    <p>WishList will never display ads. Ever. Your wishes are not data to be monetised.</p>
                </div>
            </div>
            <div class="commitment">
                <span>🧩</span>
                <div>
                    <strong>Open source</strong>
                    <p>The source code is publicly available on GitHub. Audit it, fork it, contribute to it.</p>
                </div>
            </div>
            <div class="commitment">
                <span>💶</span>
                <div>
                    <strong>Free forever</strong>
                    <p>The core functionality will always be free. No hidden fees, no premium paywall for basic features.</p>
                </div>
            </div>
            <div class="commitment">
                <span>⚖️</span>
                <div>
                    <strong>GDPR compliant</strong>
                    <p>You can export or delete all your data at any time. We only keep what is strictly necessary.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="wishlist-cta fade-in">
            <span class="badge badge--accent">Coming soon</span>
            <h2>WishList is currently in development</h2>
            <p>
                We are crafting it with the same care we apply to all EthicForge applications.
                Follow the progress on GitHub and be among the first to try it.
            </p>
            <div class="wishlist-cta__actions">
                <a class="btn btn-primary" href="https://github.com/benoit-bernard/ethicforge" target="_blank" rel="noopener noreferrer">
                    Follow on GitHub ⌥
                </a>
                <a class="btn btn-outline" href="/contact">Get notified</a>
            </div>
        </div>
    </div>
</section>
