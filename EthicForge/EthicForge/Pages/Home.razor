@page "/"

<PageTitle>EthicForge — Ethical Digital Craftsmanship</PageTitle>

<!-- ====================================================
     HERO — Logo centré plein écran
     ==================================================== -->
<section class="home-hero">
    <div class="home-hero__inner">
        <BrandOrnament Size="xl" Animated="true" />
        <h1 class="home-hero__brand">ETHICFORGE</h1>
        <p class="home-hero__sub">Ethical digital craftsmanship</p>
    </div>
    <div class="home-hero__scroll-hint">
        <span class="home-hero__scroll-line"></span>
        <span class="home-hero__scroll-label">Scroll</span>
    </div>
</section>

<!-- ====================================================
     TAGLINE — Grande accroche + maquettes téléphone
     ==================================================== -->
<section class="home-tagline">
    <div class="home-tagline__botanical" aria-hidden="true"></div>
    <div class="container">
        <div class="home-tagline__layout">
            <div class="home-tagline__content animate-on-scroll">
                <h2 class="home-tagline__heading">
                    Forger l'éthique,<br />
                    Tisser la technologie.
                </h2>
                <p class="home-tagline__body">
                    EthicForge est une forge numérique artisanale. Chaque application est construite sur des principes
                    éthiques clairs — respect de la vie privée, souveraineté européenne, transparence absolue.
                </p>
                <a class="btn-bracket home-tagline__cta" href="/philosophy">
                    Explorer la philosophie
                </a>
            </div>
            <div class="home-tagline__phones animate-on-scroll" data-delay="2">
                <div class="phone-stack">
                    <div class="phone-stack__back">
                        <PhoneMockup Variant="profile" />
                    </div>
                    <div class="phone-stack__front">
                        <PhoneMockup Variant="list" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ====================================================
     MANIFESTO — 4 piliers + téléphone + badge
     ==================================================== -->
<section class="home-manifesto">
    <div class="container">
        <h2 class="home-manifesto__title animate-on-scroll">MANIFESTO</h2>

        <div class="home-manifesto__layout">
            <div class="home-manifesto__grid">
                <div class="manifesto-item animate-on-scroll" data-delay="1">
                    <div class="manifesto-item__icon">
                        <BrandOrnament Size="sm" />
                    </div>
                    <div>
                        <h3>Privacy First</h3>
                        <p>Nous collectons uniquement le minimum indispensable au fonctionnement du service. Vos données vous appartiennent.</p>
                    </div>
                </div>

                <div class="manifesto-item animate-on-scroll" data-delay="2">
                    <div class="manifesto-item__icon">
                        <BrandOrnament Size="sm" />
                    </div>
                    <div>
                        <h3>Souveraineté européenne</h3>
                        <p>Toutes nos infrastructures sont hébergées en Europe et conformes au RGPD et au droit français.</p>
                    </div>
                </div>

                <div class="manifesto-item animate-on-scroll" data-delay="3">
                    <div class="manifesto-item__icon">
                        <BrandOrnament Size="sm" />
                    </div>
                    <div>
                        <h3>Transparence totale</h3>
                        <p>Nos choix techniques et politiques de données sont publiquement documentés. Pas de zones d'ombre.</p>
                    </div>
                </div>

                <div class="manifesto-item animate-on-scroll" data-delay="4">
                    <div class="manifesto-item__icon">
                        <BrandOrnament Size="sm" />
                    </div>
                    <div>
                        <h3>Indépendance</h3>
                        <p>Aucun fonds d'investissement. Les produits sont développés pour leur utilité, pas pour la spéculation.</p>
                    </div>
                </div>
            </div>

            <div class="home-manifesto__phone animate-on-scroll" data-delay="2">
                <PhoneMockup Variant="list" />
            </div>
        </div>

        <!-- Badge certifié -->
        <div class="home-badge animate-on-scroll">
            <div class="home-badge__inner">
                <BrandOrnament Size="md" />
                <div class="home-badge__text">
                    <span class="home-badge__name">EthicForge</span>
                    <span class="home-badge__label">Certified</span>
                </div>
            </div>
        </div>
    </div>
</section>


