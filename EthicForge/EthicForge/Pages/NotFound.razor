@page "/not-found"
@layout MainLayout

<PageTitle>404 — EthicForge</PageTitle>

<div class="notfound">
    <div class="notfound__glow"></div>
    <div class="container">
        <div class="notfound__content animate-on-scroll">
            <span class="notfound__code">404</span>
            <h1 class="notfound__title">Page not found</h1>
            <p class="notfound__message">
                The page you are looking for does not exist or has been moved.
                Let's get you back on track.
            </p>
            <div class="notfound__actions">
                <a class="btn btn-primary" href="/">Back to Home</a>
                <a class="btn btn-outline" href="/contact">Contact us</a>
            </div>
        </div>
    </div>
</div>
