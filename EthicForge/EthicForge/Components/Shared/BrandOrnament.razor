<svg class="brand-ornament brand-ornament--@Size @(Animated ? "brand-ornament--animated" : "")"
     viewBox="0 0 120 120"
     xmlns="http://www.w3.org/2000/svg"
     aria-hidden="true">

    <!-- Outer dashed ring -->
    <circle cx="60" cy="60" r="57"
            style="fill:none; stroke:var(--color-primary); stroke-width:0.5; stroke-dasharray:2,6; opacity:0.55" />

    <!-- 8 outer pointed petals -->
    <path d="M60,5 L63.5,18 L60,28 L56.5,18 Z"
          style="fill:rgba(196,163,90,0.18); stroke:var(--color-primary); stroke-width:0.5" />
    <path d="M60,5 L63.5,18 L60,28 L56.5,18 Z"
          style="fill:rgba(196,163,90,0.18); stroke:var(--color-primary); stroke-width:0.5" transform="rotate(45 60 60)" />
    <path d="M60,5 L63.5,18 L60,28 L56.5,18 Z"
          style="fill:rgba(196,163,90,0.18); stroke:var(--color-primary); stroke-width:0.5" transform="rotate(90 60 60)" />
    <path d="M60,5 L63.5,18 L60,28 L56.5,18 Z"
          style="fill:rgba(196,163,90,0.18); stroke:var(--color-primary); stroke-width:0.5" transform="rotate(135 60 60)" />
    <path d="M60,5 L63.5,18 L60,28 L56.5,18 Z"
          style="fill:rgba(196,163,90,0.18); stroke:var(--color-primary); stroke-width:0.5" transform="rotate(180 60 60)" />
    <path d="M60,5 L63.5,18 L60,28 L56.5,18 Z"
          style="fill:rgba(196,163,90,0.18); stroke:var(--color-primary); stroke-width:0.5" transform="rotate(225 60 60)" />
    <path d="M60,5 L63.5,18 L60,28 L56.5,18 Z"
          style="fill:rgba(196,163,90,0.18); stroke:var(--color-primary); stroke-width:0.5" transform="rotate(270 60 60)" />
    <path d="M60,5 L63.5,18 L60,28 L56.5,18 Z"
          style="fill:rgba(196,163,90,0.18); stroke:var(--color-primary); stroke-width:0.5" transform="rotate(315 60 60)" />

    <!-- Outer connecting ring -->
    <circle cx="60" cy="60" r="43"
            style="fill:none; stroke:var(--color-primary); stroke-width:0.5; opacity:0.45" />

    <!-- Two overlapping squares — 8-pointed star frame -->
    <rect x="22" y="22" width="76" height="76"
          style="fill:none; stroke:var(--color-primary); stroke-width:0.6; opacity:0.5" />
    <rect x="22" y="22" width="76" height="76"
          style="fill:none; stroke:var(--color-primary); stroke-width:0.6; opacity:0.5"
          transform="rotate(45 60 60)" />

    <!-- Middle ring -->
    <circle cx="60" cy="60" r="26"
            style="fill:rgba(196,163,90,0.05); stroke:var(--color-primary); stroke-width:0.7" />

    <!-- 6 inner petals (ellipses) -->
    <ellipse cx="60" cy="42" rx="4" ry="10"
             style="fill:rgba(196,163,90,0.22); stroke:var(--color-primary); stroke-width:0.5" />
    <ellipse cx="60" cy="42" rx="4" ry="10"
             style="fill:rgba(196,163,90,0.22); stroke:var(--color-primary); stroke-width:0.5"
             transform="rotate(60 60 60)" />
    <ellipse cx="60" cy="42" rx="4" ry="10"
             style="fill:rgba(196,163,90,0.22); stroke:var(--color-primary); stroke-width:0.5"
             transform="rotate(120 60 60)" />
    <ellipse cx="60" cy="42" rx="4" ry="10"
             style="fill:rgba(196,163,90,0.22); stroke:var(--color-primary); stroke-width:0.5"
             transform="rotate(180 60 60)" />
    <ellipse cx="60" cy="42" rx="4" ry="10"
             style="fill:rgba(196,163,90,0.22); stroke:var(--color-primary); stroke-width:0.5"
             transform="rotate(240 60 60)" />
    <ellipse cx="60" cy="42" rx="4" ry="10"
             style="fill:rgba(196,163,90,0.22); stroke:var(--color-primary); stroke-width:0.5"
             transform="rotate(300 60 60)" />

    <!-- Inner circle -->
    <circle cx="60" cy="60" r="9"
            style="fill:rgba(196,163,90,0.12); stroke:var(--color-primary); stroke-width:0.7" />

    <!-- Center dot -->
    <circle cx="60" cy="60" r="4.5"
            style="fill:var(--color-primary)" />
</svg>

@code {
    [Parameter] public string Size { get; set; } = "md";
    [Parameter] public bool Animated { get; set; } = false;
}
